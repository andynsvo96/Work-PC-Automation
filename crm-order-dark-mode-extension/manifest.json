{
  "manifest_version": 3,
  "name": "CRM Order Assistant",
  "version": "1.2.0",
  "description": "Dark mode and paired, single-order processing controls for Printfly CRM order pages.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://crm2.legacy.printfly.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "CRM Order Assistant",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://crm2.legacy.printfly.com/*"],
      "js": ["content.js"],
      "css": ["dark-mode.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
